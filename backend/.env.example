# ============================================
# Hardoi ki Awaaz - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values
#   cp .env.example .env
#
# Get Gemini API Key: https://aistudio.google.com/apikey

# REQUIRED: Google Gemini API Key (Primary)
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: Backup Gemini API Key (fallback when primary hits rate limit)
GEMINI_API_KEY_2=

# OPTIONAL: Google Custom Search API Key (for image search in news)
GOOGLE_API_KEY=

# OPTIONAL: Server port (default: 3001)
PORT=3001

# OPTIONAL: Content refresh interval in minutes (default: 60)
REFRESH_INTERVAL_MINUTES=60

# OPTIONAL: CORS allowed origin (default: allow all origins)
# In production, set this to your frontend domain for security
# CORS_ORIGIN=https://your-frontend-domain.onrender.com
